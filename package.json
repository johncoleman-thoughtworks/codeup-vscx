{
  "name": "codeup",
  "displayName": "Codeup",
  "description": "Coding anti-pattern findings for your codebase, powered by Claude.",
  "version": "1.2.1",
  "publisher": "johncoleman-thoughtworks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johncoleman-thoughtworks/codeup-vscx.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "architecture",
    "anti-patterns",
    "code review",
    "claude",
    "anthropic",
    "static analysis",
    "code quality",
    "sarif"
  ],
  "main": "./dist/extension.js",
  "icon": "resources/codeup-marketplace.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeup",
          "title": "Codeup",
          "icon": "resources/codeup-icon.svg"
        }
      ]
    },
    "views": {
      "codeup": [
        {
          "id": "codeup.findings",
          "name": "Findings"
        }
      ]
    },
    "commands": [
      {
        "command": "codeup.scan.full",
        "title": "Codeup: Run Full Scan"
      },
      {
        "command": "codeup.scan.file",
        "title": "Codeup: Scan Current File"
      },
      {
        "command": "codeup.scan.openTabs",
        "title": "Codeup: Scan Open Tabs"
      },
      {
        "command": "codeup.findings.refresh",
        "title": "Codeup: Refresh Findings",
        "icon": "$(refresh)"
      },
      {
        "command": "codeup.findings.openFinding",
        "title": "Codeup: Open Finding"
      },
      {
        "command": "codeup.findings.focus",
        "title": "Codeup: Focus Findings Panel"
      },
      {
        "command": "codeup.findings.groupBy.severity",
        "title": "Codeup: Group Findings by Severity"
      },
      {
        "command": "codeup.findings.groupBy.category",
        "title": "Codeup: Group Findings by Category"
      },
      {
        "command": "codeup.findings.groupBy.status",
        "title": "Codeup: Group Findings by Status"
      },
      {
        "command": "codeup.apiKey.set",
        "title": "Codeup: Set Anthropic API Key"
      },
      {
        "command": "codeup.apiKey.clear",
        "title": "Codeup: Clear Anthropic API Key"
      },
      {
        "command": "codeup.intent.suggest",
        "title": "Codeup: Suggest Architectural Intent"
      },
      {
        "command": "codeup.updateCheck.now",
        "title": "Codeup: Check for Updates"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codeup.findings.refresh",
          "when": "view == codeup.findings",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Codeup",
      "properties": {
        "codeup.modelProvider": {
          "type": "string",
          "enum": ["auto", "anthropic", "copilot"],
          "default": "auto",
          "description": "Which LLM provider to use. 'auto' picks Anthropic if an API key is set in SecretStorage, otherwise falls back to GitHub Copilot via the Language Model API. 'anthropic' and 'copilot' force a specific provider."
        },
        "codeup.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model used for analysis (only consulted when the active provider is Anthropic)."
        },
        "codeup.scan.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Run incremental scans on file save."
        },
        "codeup.findingsDir": {
          "type": "string",
          "default": ".codeup/findings",
          "description": "Directory (relative to workspace root) where findings are stored."
        },
        "codeup.fileSize.warnBytes": {
          "type": "number",
          "default": 30000,
          "description": "File size in bytes at or above which an oversized-file finding is emitted at medium severity."
        },
        "codeup.fileSize.criticalBytes": {
          "type": "number",
          "default": 60000,
          "description": "File size in bytes at or above which an oversized-file finding is emitted at high severity. Should match the analyzer's character cap so files skipped by the LLM pass are flagged."
        },
        "codeup.updateCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Check GitHub Releases for newer Codeup versions on activation. When a newer version is found, shows a notification with an option to download and install the .vsix. Set to false to disable the check entirely (no network call)."
        },
        "codeup.updateCheck.intervalHours": {
          "type": "number",
          "default": 24,
          "description": "Minimum hours between update checks. Subsequent activations within this window skip the network call."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run security:check && npm run compile",
    "security:check": "npm run security:audit && npm run security:lockfile",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:lockfile": "npm ci --omit=dev --dry-run --ignore-scripts >/dev/null && echo 'lockfile integrity ✓'",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile",
    "test": "npm run test:unit",
    "test:unit": "node --test 'dist/test/unit/*.test.js'",
    "test:integration": "node ./dist/test/integration/runTest.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "ignore": "^5.3.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
